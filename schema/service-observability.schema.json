{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://am.local/schema/service-observability.schema.json",
  "title": "ServiceObservability",
  "description": "Per-service observability manifest (lives in each service repo).",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "apiVersion",
    "kind",
    "service",
    "tier",
    "runtime",
    "k8s_app_label",
    "namespace",
    "signals"
  ],
  "properties": {
    "apiVersion": { "type": "string", "const": "am.obs/v1" },
    "kind": { "type": "string", "const": "ServiceObservability" },
    "service": { "type": "string", "minLength": 1 },
    "tier": { "type": "string", "enum": ["A", "B"] },
    "runtime": { "type": "string", "enum": ["java", "python"] },
    "k8s_app_label": { "type": "string", "minLength": 1 },
    "namespace": { "type": "string", "minLength": 1 },
    "metrics_application": {
      "type": "string",
      "minLength": 1,
      "description": "Prometheus/Micrometer application label (defaults to service). Use when spring.application.name differs from service id."
    },
    "owners": {
      "type": "array",
      "items": { "type": "string" }
    },
    "signals": {
      "type": "object",
      "properties": {
        "bundle": { "type": "string", "minLength": 1 },
        "include": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "domain": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "groups": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "uses": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": true
    },
    "functional": {
      "type": "array",
      "items": { "type": "string" }
    },
    "dashboard": {
      "type": "object",
      "description": "Plane C: panel/row visibility for optional service-view compose. Omit to use shared tech-am-services only.",
      "additionalProperties": false,
      "properties": {
        "technical": { "$ref": "#/$defs/dashboardPrefs" },
        "functional": { "$ref": "#/$defs/dashboardPrefs" }
      }
    }
  },
  "$defs": {
    "dashboardPrefs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "panels": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "include": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "description": "If set, only these panel ids (and matching signal ids) are kept"
            },
            "exclude": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "rows": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "hide": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "description": "Row ids to drop entirely (e.g. row_mongo)"
            },
            "collapse": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}
